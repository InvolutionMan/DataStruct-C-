{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run cpp",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "clear; clang++ -std=c++23 \"${file}\" -o \"${fileBasenameNoExtension}\" && exec \"./${fileBasenameNoExtension}\""
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}